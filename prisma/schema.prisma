// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post{
  id String @default(uuid()) @unique @id
  title String
  content String
  image String?
  createdAt DateTime @default(now())
  tags String[]
}
enum Status{
  wip
  maintained
  archived
}

model Project {
  id String @unique @default(cuid()) @id
  title String
  description String
  href String
  status Status
}

model WorkExperience{
  id String @unique @default(cuid()) @id
  title String
  href String
  buttonText String
  status String?
}

model lastUpdated{
  lastUpdate DateTime @unique @default(now()) @id
}

model Now {
  id String @unique @id
  title String 
  contents String[]
}